// Save/Update design modal functions
let currentSaveMode='save';//'save' or 'update'
function showSaveModal(){
  currentSaveMode='save';
  const updateBtn=document.getElementById('updateBtn');
  if(updateBtn)updateBtn.style.display='none';
  window.pendingDesignLoad=null;
  window.currentEditingDesignId=null;
  document.getElementById('saveModalTitle').textContent='保存设计方案';
  document.getElementById('saveDesignName').value='';
  document.getElementById('saveDesignModal').classList.add('show');
  document.getElementById('saveDesignName').focus();
}
function showUpdateModal(){
  currentSaveMode='update';
  const designId=window.currentEditingDesignId;
  if(!designId){showToast('error','未找到要更新的方案');return;}
  const savedDesigns=JSON.parse(localStorage.getItem('mgilt_designs')||'[]');
  const design=savedDesigns.find(d=>d.id===designId);
  if(!design){showToast('error','未找到要更新的方案');return;}
  window.pendingDesignLoad=design;
  document.getElementById('saveModalTitle').textContent='更新设计方案';
  document.getElementById('saveDesignName').value=design.name||'';
  document.getElementById('saveDesignModal').classList.add('show');
  document.getElementById('saveDesignName').focus();
}
function closeSaveModal(){
  document.getElementById('saveDesignModal').classList.remove('show');
}
function doSaveDesign(){
  const name=document.getElementById('saveDesignName').value.trim();
  if(!name){showToast('error','请输入方案名称');return;}
  if(currentSaveMode==='update'){
    window.updateDesignToAccount(name);
  }else{
    window.saveDesignFromModal(name);
  }
  closeSaveModal();
}
window.showSaveModal=showSaveModal;
window.showUpdateModal=showUpdateModal;
window.closeSaveModal=closeSaveModal;
