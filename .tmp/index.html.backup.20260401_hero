function doLogin(){
  clearAllErrors();
  const emailOrPhone=document.getElementById('loginEmail').value.trim();
  const password=document.getElementById('loginPassword').value;
  const rememberMe=document.getElementById('rememberMe').checked;
  let hasError=false;
  if(!emailOrPhone){setError('loginEmail','请输入电子邮箱或手机号码');hasError=true;}
  else if(!validateEmail(emailOrPhone) && !validatePhone(emailOrPhone)){setError('loginEmail','请输入有效的邮箱地址或手机号码');hasError=true;}
  if(!password){setError('loginPassword','请输入密码');hasError=true;}
  if(hasError)return;
  setButtonLoading('loginBtn',true);
  setTimeout(()=>{
    const users=getUsers();
    let user=users[emailOrPhone];
    if(!user && validatePhone(emailOrPhone)){
      for(const [key,u] of Object.entries(users)){
        if(u.phone===emailOrPhone){user=u;break;}
      }
    }
    if(!user){setButtonLoading('loginBtn',false);showToast('error','该账号尚未注册');return;}
    if(user.password!==password){setButtonLoading('loginBtn',false);setError('loginPassword','密码错误');return;}
    const session={email:user.email,name:user.name,userType:user.userType,loginTime:new Date().toISOString()};
    saveSession(session);
    if(rememberMe){localStorage.setItem('mgilt_remember',emailOrPhone);}
    setButtonLoading('loginBtn',false);
    updateUIForLoginState();
    showToast('success','欢迎回来，'+user.name+'！');
    navigateTo(user.userType==='dealer'?'dealer':'dashboard');
  },800);
}

/* === REGISTER === */
function doRegister(){
  clearAllErrors();
  const name=document.getElementById('regName').value.trim();
  const email=document.getElementById('regEmail').value.trim();
  const phone=document.getElementById('regPhone').value.trim();
  const password=document.getElementById('regPassword').value;
  const confirmPassword=document.getElementById('regConfirmPassword').value;
  const userType=document.getElementById('regUserType').value;
  const agreeTerms=document.getElementById('agreeTerms').checked;
  let hasError=false;
  let userId=email;
  if(!name){setError('regName','请输入姓名');hasError=true;}
  if(email && !validateEmail(email)){setError('regEmail','请输入有效的邮箱地址');hasError=true;}
  if(phone && !validatePhone(phone)){setError('regPhone','请输入有效的手机号码');hasError=true;}
  if(!email && !phone){setError('regEmail','请输入电子邮箱或手机号码');hasError=true;}
  if(!password){setError('regPassword','请设置密码');hasError=true;}
  else if(password.length<8){setError('regPassword','密码至少8位');hasError=true;}
  if(!confirmPassword){setError('regConfirmPassword','请确认密码');hasError=true;}
  else if(password!==confirmPassword){setError('regConfirmPassword','两次密码不一致');hasError=true;}
  if(!agreeTerms){setError('agreeTermsError','请勾选同意用户协议');hasError=true;}
  if(hasError)return;
  if(!email && phone){userId='phone_'+phone;}
  setButtonLoading('registerBtn',true);
  setTimeout(()=>{
    const users=getUsers();
    if(users[userId]){setButtonLoading('registerBtn',false);showToast('error','该账号已被注册');return;}
    users[userId]={email:userId,name,phone,password,userType,createdAt:new Date().toISOString()};
    saveUsers(users);
    setButtonLoading('registerBtn',false);
    document.getElementById('successTitle').textContent='注册成功';
    document.getElementById('successMessage').textContent='您已成功注册，现在可以登录了。';
    document.getElementById('successModal').classList.add('show');
  },1000);
}

