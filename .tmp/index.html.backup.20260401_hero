window.confirmDeleteDesign=confirmDeleteDesign;

/* === PROFILE EDIT === */
function showProfileEdit(){
  const session=JSON.parse(localStorage.getItem('mgilt_session')||'null');
  if(!session){showToast('info','请先登录');return;}
  document.getElementById('profileNameInput').value=session.name||'';
  const avatarImg=document.getElementById('avatarPreview');
  if(session.avatar){
    avatarImg.src=session.avatar;
    avatarImg.style.display='block';
  }else{
    avatarImg.src='';
    avatarImg.style.display='none';
  }
  document.getElementById('profileEditModal').classList.add('show');
}
function closeProfileEdit(){
  document.getElementById('profileEditModal').classList.remove('show');
}
function handleAvatarChange(input){
  const file=input.files[0];
  if(!file)return;
  const reader=new FileReader();
  reader.onload=function(e){
    document.getElementById('avatarPreview').src=e.target.result;
    document.getElementById('avatarPreview').style.display='block';
  };
  reader.readAsDataURL(file);
}
function saveProfileEdit(){
  const session=JSON.parse(localStorage.getItem('mgilt_session')||'null');
  if(!session){showToast('error','请先登录');return;}
  const newName=document.getElementById('profileNameInput').value.trim();
  if(!newName){showToast('error','用户名不能为空');return;}
  session.name=newName;
  const avatarSrc=document.getElementById('avatarPreview').src;
  if(avatarSrc && avatarSrc!==window.location.href){
    session.avatar=avatarSrc;
  }
  localStorage.setItem('mgilt_session',JSON.stringify(session));
  const users=JSON.parse(localStorage.getItem('mgilt_users')||'{}');
  if(users[session.email]){
    users[session.email].name=newName;
    users[session.email].avatar=session.avatar;
    localStorage.setItem('mgilt_users',JSON.stringify(users));
  }
  updateUIForLoginState();
  closeProfileEdit();
  showToast('success','个人信息已更新');
}
window.showProfileEdit=showProfileEdit;
window.closeProfileEdit=closeProfileEdit;
window.handleAvatarChange=handleAvatarChange;
window.saveProfileEdit=saveProfileEdit;

