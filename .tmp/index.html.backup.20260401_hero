/* === PASSWORD STRENGTH === */
function checkPasswordStrength(){
  const password=document.getElementById('regPassword').value;
  const strengthDiv=document.getElementById('passwordStrength');
  const fill=document.getElementById('strengthFill');
  const text=document.getElementById('strengthText');
  if(!password){strengthDiv.classList.remove('show');return;}
  strengthDiv.classList.add('show');
  let strength=0;
  if(password.length>=8)strength++;
  if(/[A-Z]/.test(password))strength++;
  if(/[0-9]/.test(password))strength++;
  if(/[^A-Za-z0-9]/.test(password))strength++;
  fill.className='strength-fill';
  if(strength<=1){fill.classList.add('weak');text.textContent='密码强度：弱';}
  else if(strength<=2){fill.classList.add('medium');text.textContent='密码强度：中等';}
  else{fill.classList.add('strong');text.textContent='密码强度：强';}
}

/* === VALIDATION HELPERS === */
function clearError(fieldId){const el=document.getElementById(fieldId);if(el)el.classList.remove('error');const err=document.getElementById(fieldId+'Error');if(err)err.textContent='';}
function setError(fieldId,message){const el=document.getElementById(fieldId);if(el)el.classList.add('error');const err=document.getElementById(fieldId+'Error');if(err)err.textContent=message;}
function clearAllErrors(){document.querySelectorAll('.form-group input,.form-group select').forEach(el=>el.classList.remove('error'));document.querySelectorAll('.form-error').forEach(el=>el.textContent='');}
function validateEmail(email){return/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);}
function validatePhone(phone){return!phone||/^1[3-9]\d{9}$/.test(phone);}

/* === USER SESSION MANAGEMENT === */
const USERS_KEY='mgilt_users';
const SESSION_KEY='mgilt_session';
function getUsers(){return JSON.parse(localStorage.getItem(USERS_KEY)||'{}');}
function saveUsers(users){localStorage.setItem(USERS_KEY,JSON.stringify(users));}
function getSession(){return JSON.parse(localStorage.getItem(SESSION_KEY)||'null');}
function saveSession(user){localStorage.setItem(SESSION_KEY,JSON.stringify(user));}
function clearSession(){localStorage.removeItem(SESSION_KEY);}
function isLoggedIn(){return!!getSession();}

/* === UPDATE UI FOR LOGGED IN STATE === */
function updateUIForLoginState(){
  const session=getSession();
  const navLoginContainer=document.getElementById('navLoginContainer');
  const userDropdown=document.getElementById('userDropdown');
  const mobileNavLogin=document.getElementById('mobileNavLogin');
  const mobileNavDashboard=document.getElementById('mobileNavDashboard');
  const mobileNavLogout=document.getElementById('mobileNavLogout');
  const userAvatar=document.getElementById('userAvatar');
  const userName=document.getElementById('userName');
  const dashAvatar=document.getElementById('dashAvatar');
  const dashUserTitle=document.getElementById('dashUserTitle');
  const dashUserEmail=document.getElementById('dashUserEmail');
  const dashNav=document.getElementById('dashNav');
  const dealerDashNav=document.getElementById('dealerDashNav');
  const navDealer=document.getElementById('navDealer');
  if(session){
    navLoginContainer.style.display='none';
    userDropdown.style.display='block';
    mobileNavLogin.style.display='none';
    mobileNavDashboard.style.display='flex';
    mobileNavLogout.style.display='flex';
    const initial=session.name?session.name.charAt(0).toUpperCase():'M';
    if(userAvatar)userAvatar.textContent=initial;
    if(userName)userName.textContent=session.name||'用户';
    if(dashAvatar){
      const dashAvatarImg=document.getElementById('dashAvatarImg');
      const dashAvatarInitial=document.getElementById('dashAvatarInitial');
      if(session.avatar){
        if(dashAvatarImg){dashAvatarImg.src=session.avatar;dashAvatarImg.style.display='block';}
        if(dashAvatarInitial){dashAvatarInitial.textContent='';}
        dashAvatar.style.background='none';
      }else{
        if(dashAvatarImg){dashAvatarImg.style.display='none';}
        if(dashAvatarInitial){dashAvatarInitial.textContent=initial;}
        dashAvatar.style.background='var(--sage-light)';
        dashAvatar.style.color='var(--sage)';
      }
    }
    if(dashUserTitle)dashUserTitle.textContent=session.name||(session.userType==='dealer'?'经销商中心':'用户中心');
    if(dashUserEmail)dashUserEmail.textContent=session.email;
    if(session.userType==='dealer'){
      if(dashNav)dashNav.style.display='none';
      if(dealerDashNav)dealerDashNav.style.display='block';
      if(navDealer)navDealer.style.display='block';
    }
  }else{
    navLoginContainer.style.display='block';
    userDropdown.style.display='none';
    mobileNavLogin.style.display='flex';
    mobileNavDashboard.style.display='none';
    mobileNavLogout.style.display='none';
    if(navDealer)navDealer.style.display='none';
  }
}
window.clearSession=clearSession;
window.updateUIForLoginState=updateUIForLoginState;

/* === LOGIN === */
function setButtonLoading(btnId,loading,originalText){
  const btn=document.getElementById(btnId);
  if(!btn)return;
  const textEl=btn.querySelector('.btn-text');
  const loadingEl=btn.querySelector('.btn-loading');
  if(loading){btn.disabled=true;if(textEl)textEl.style.display='none';if(loadingEl)loadingEl.style.display='flex';}
  else{btn.disabled=false;if(textEl)textEl.style.display='inline';if(loadingEl)loadingEl.style.display='none';}
}

/* === PHONE LOGIN === */
function showPhoneLogin(){
  document.getElementById('phoneLoginModal').classList.add('show');
  document.getElementById('phoneLoginNumber').value='';
  document.getElementById('phoneLoginCode').value='';
  clearAllErrors();
}
function closePhoneLogin(){
  document.getElementById('phoneLoginModal').classList.remove('show');
}
function sendPhoneCode(){
  const phone=document.getElementById('phoneLoginNumber').value.trim();
  if(!phone){setError('phoneLoginNumberError','请输入手机号码');return;}
  if(!validatePhone(phone)){setError('phoneLoginNumberError','请输入有效的手机号码');return;}
  const btn=document.getElementById('sendCodeBtn');
  btn.disabled=true;
  btn.textContent='59秒后重试';
  let countdown=59;
  const timer=setInterval(()=>{
    countdown--;
    if(countdown<=0){
      clearInterval(timer);
      btn.disabled=false;
      btn.textContent='获取验证码';
    }else{
      btn.textContent=countdown+'秒后重试';
    }
  },1000);
  showToast('success','验证码已发送：1234');
}
function doPhoneLogin(){
  clearAllErrors();
  const phone=document.getElementById('phoneLoginNumber').value.trim();
  const code=document.getElementById('phoneLoginCode').value.trim();
  let hasError=false;
  if(!phone){setError('phoneLoginNumberError','请输入手机号码');hasError=true;}
  else if(!validatePhone(phone)){setError('phoneLoginNumberError','请输入有效的手机号码');hasError=true;}
  if(!code){setError('phoneLoginCodeError','请输入验证码');hasError=true;}
  if(code!=='1234'){setError('phoneLoginCodeError','验证码错误');hasError=true;}
  if(hasError)return;
  setButtonLoading('phoneLoginBtn',true);
  setTimeout(()=>{
    const users=getUsers();
    let user=null;
    let userEmail=null;
    for(const [email,u] of Object.entries(users)){
      if(u.phone===phone){user=u;userEmail=email;break;}
    }
    if(!user){
      setButtonLoading('phoneLoginBtn',false);
      showToast('error','该手机号尚未注册，请先注册');
      setTimeout(()=>{closePhoneLogin();showPhoneReg();},1500);
      return;
    }
    const session={email:userEmail,name:user.name,userType:user.userType,loginTime:new Date().toISOString()};
    saveSession(session);
    setButtonLoading('phoneLoginBtn',false);
    closePhoneLogin();
    updateUIForLoginState();
    showToast('success','登录成功，欢迎回来，'+user.name+'！');
    navigateTo(user.userType==='dealer'?'dealer':'dashboard');
  },800);
}

