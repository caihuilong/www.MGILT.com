<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MGILT 麦吉蓝图 — 模块化生态空间</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
<script src="js/gsap.min.js"></script>
<script src="js/ScrollTrigger.min.js"></script>
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"
  }
}
</script>
<style>
/* === RESET & VARIABLES === */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--black:#0a0a0a;--white:#fafaf8;--sage:#7A9E7E;--sage-light:#e8f0e9;--beige:#BFA27A;--beige-light:#f5f0e8;
--gray-100:#f5f5f3;--gray-200:#e8e8e5;--gray-300:#d1d1cd;--gray-400:#a0a09b;--gray-500:#6b6b66;--gray-600:#3d3d3a;
--font-display:'DM Sans',sans-serif;--font-body:'Noto Sans SC','DM Sans',sans-serif;
--nav-h:64px;--page-pad:clamp(24px,5vw,80px);
--ease-out:cubic-bezier(0.16,1,0.3,1);--ease-in-out:cubic-bezier(0.65,0,0.35,1);
}
html{scroll-behavior:smooth;font-size:16px;overflow-x:hidden}
body{font-family:var(--font-body);font-weight:400;color:var(--black);background:var(--white);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
img{max-width:100%;display:block}
ul{list-style:none}
input,select,textarea{font-family:inherit;font-size:inherit}

/* === UTILITY === */
.container{max-width:1320px;margin:0 auto;padding:0 var(--page-pad)}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}

/* === NAVIGATION === */
.nav{position:fixed;top:0;left:0;right:0;height:var(--nav-h);background:rgba(250,250,248,.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);z-index:1000;border-bottom:1px solid rgba(0,0,0,.06);transition:transform .4s var(--ease-out)}
.nav.hidden{transform:translateY(-100%)}
.nav-inner{max-width:1440px;margin:0 auto;padding:0 var(--page-pad);display:flex;align-items:center;justify-content:space-between;height:100%}
.nav-logo{font-family:var(--font-display);font-weight:500;font-size:20px;letter-spacing:3px;cursor:pointer;display:flex;align-items:center;gap:8px}
.nav-logo .dot{width:8px;height:8px;background:var(--sage);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%)}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:13px;font-weight:400;letter-spacing:.5px;position:relative;padding:4px 0;transition:color .3s}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--black);transition:width .3s var(--ease-out)}
.nav-links a:hover::after,.nav-links a.active::after{width:100%}
.nav-right{display:flex;align-items:center;gap:20px}
.nav-right a{font-size:13px;letter-spacing:.3px}
.nav-cta{font-size:12px!important;padding:8px 20px;border:1px solid var(--black);letter-spacing:1px;transition:all .3s}
.nav-cta:hover{background:var(--black);color:var(--white)}
.nav-icon-btn{background:none;border:none;cursor:pointer;padding:8px;color:var(--black);transition:color .3s;display:flex;align-items:center;justify-content:center}
.nav-icon-btn:hover{color:var(--sage)}
.user-dropdown{position:relative}
.user-dropdown-menu{display:none;position:absolute;top:100%;right:0;background:var(--white);border:1px solid var(--gray-200);min-width:160px;z-index:100;margin-top:4px;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.user-dropdown-menu.show{display:block}
.user-dropdown-menu a{display:block;padding:10px 16px;font-size:13px;color:var(--black);transition:background .2s}
.user-dropdown-menu a:hover{background:var(--gray-100)}
.user-icon-btn{padding:6px!important;border-radius:50%;background:var(--gray-100)}
.user-icon-btn:hover{background:var(--sage);color:var(--white)!important}
.nav-partner{color:var(--sage)!important;font-weight:500!important}
.nav-partner:hover{color:var(--black)!important}
.mobile-toggle{display:none;flex-direction:column;gap:5px;width:24px;cursor:pointer}
.mobile-toggle span{display:block;height:1.5px;background:var(--black);transition:all .3s}
.mobile-menu{display:none;position:fixed;inset:0;top:var(--nav-h);background:var(--white);z-index:999;padding:40px var(--page-pad);flex-direction:column;gap:24px}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:24px;font-weight:300;font-family:var(--font-display)}

/* === PAGE SYSTEM === */
.page{display:none;min-height:100vh;opacity:0;transition:opacity .5s var(--ease-out)}
.page.active{display:block;opacity:1}
.page-hero{padding-top:calc(var(--nav-h) + 80px);padding-bottom:80px}

/* === BUTTONS === */
.btn{display:inline-flex;align-items:center;gap:8px;font-size:13px;letter-spacing:1.5px;font-weight:400;padding:14px 36px;transition:all .4s var(--ease-out);text-transform:uppercase}
.btn-primary{background:var(--black);color:var(--white);border:1px solid var(--black)}
.btn-primary:hover{background:transparent;color:var(--black)}
.btn-outline{border:1px solid var(--black);color:var(--black)}
.btn-outline:hover{background:var(--black);color:var(--white)}
.btn-sage{background:var(--sage);color:var(--white);border:1px solid var(--sage)}
.btn-sage:hover{background:#5f8563}
.btn-sm{padding:10px 24px;font-size:12px}
.btn-arrow::after{content:'→';transition:transform .3s}
.btn-arrow:hover::after{transform:translateX(4px)}

/* === SECTION TITLES === */
.section-label{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gray-400);margin-bottom:16px;font-family:var(--font-display)}
.section-title{font-family:var(--font-display);font-size:clamp(28px,4vw,48px);font-weight:300;line-height:1.2;margin-bottom:24px;letter-spacing:-0.5px}
.section-subtitle{font-size:15px;color:var(--gray-500);max-width:560px;line-height:1.8;font-weight:300}

/* === FOOTER === */
.footer{background:var(--black);color:var(--white);padding:80px 0 40px}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px}
.footer-brand{font-family:var(--font-display);font-size:18px;letter-spacing:3px;margin-bottom:16px}
.footer-desc{font-size:13px;color:var(--gray-400);line-height:1.8;max-width:280px}
.footer h4{font-size:11px;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;color:var(--gray-400)}
.footer a{font-size:13px;color:var(--gray-300);display:block;padding:4px 0;transition:color .3s}
.footer a:hover{color:var(--white)}
.footer-newsletter{margin-top:16px;display:flex;border-bottom:1px solid var(--gray-600)}
.footer-newsletter input{background:none;border:none;color:var(--white);padding:8px 0;flex:1;font-size:13px;outline:none}
.footer-newsletter input::placeholder{color:var(--gray-500)}
.footer-newsletter button{color:var(--gray-400);font-size:13px;transition:color .3s}
.footer-newsletter button:hover{color:var(--white)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding-top:24px;display:flex;justify-content:space-between;font-size:12px;color:var(--gray-500)}

/* === RESPONSIVE === */
@media(max-width:900px){
.nav-links{display:none}
.mobile-toggle{display:flex}
.footer-grid{grid-template-columns:1fr 1fr;gap:40px}
}
@media(max-width:600px){
.footer-grid{grid-template-columns:1fr}
}

/* === HOME PAGE === */
.home-hero{min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;background:var(--white)}
.home-hero-bg{position:absolute;inset:0;opacity:.06}
.home-hero-bg svg{width:100%;height:100%}
.home-hero-content{text-align:center;position:relative;z-index:2;padding:0 24px}
.home-hero-label{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--gray-400);margin-bottom:32px;font-family:var(--font-display)}
.home-hero h1{font-family:var(--font-display);font-size:clamp(48px,8vw,96px);font-weight:300;letter-spacing:8px;margin-bottom:16px;line-height:1.1}
.home-hero h1 .accent{color:var(--sage)}
.home-hero-tagline{font-size:clamp(14px,2vw,18px);font-weight:300;color:var(--gray-500);letter-spacing:2px;margin-bottom:48px}
.home-hero-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

.home-philosophy{padding:120px 0;background:var(--white)}
.home-philosophy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:48px;margin-top:64px}
.phil-card{padding:48px 36px;border:1px solid var(--gray-200);transition:all .5s var(--ease-out)}
.phil-card:hover{border-color:var(--sage);background:var(--sage-light)}
.phil-icon{width:48px;height:48px;margin-bottom:24px;display:flex;align-items:center;justify-content:center}
.phil-icon svg{width:32px;height:32px;stroke:var(--sage);fill:none;stroke-width:1.5}
.phil-card h3{font-family:var(--font-display);font-size:18px;font-weight:400;margin-bottom:8px;letter-spacing:.5px}
.phil-card .en{font-size:11px;letter-spacing:2px;color:var(--gray-400);text-transform:uppercase;margin-bottom:16px;font-family:var(--font-display)}
.phil-card p{font-size:14px;color:var(--gray-500);line-height:1.8}

.home-showcase{padding:120px 0;background:var(--gray-100)}
.home-showcase-visual{margin-top:64px;height:clamp(300px,50vw,560px);background:linear-gradient(135deg,var(--sage-light),var(--beige-light));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.hex-pattern-showcase{display:flex;flex-wrap:wrap;gap:4px;transform:rotate(-5deg) scale(1.2);opacity:.5}
.hex-sm{width:60px;height:52px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%)}

.home-quote{padding:120px 0;text-align:center}
.home-quote blockquote{font-family:var(--font-display);font-size:clamp(20px,3.5vw,36px);font-weight:300;line-height:1.6;max-width:700px;margin:0 auto;letter-spacing:.5px;color:var(--gray-600)}
.home-quote .quote-line{width:48px;height:1px;background:var(--sage);margin:24px auto 0}

.home-partners{padding:80px 0;border-top:1px solid var(--gray-200)}
.partners-row{display:flex;justify-content:center;align-items:center;gap:clamp(32px,6vw,80px);margin-top:48px;flex-wrap:wrap}
.partner-logo{font-family:var(--font-display);font-size:18px;letter-spacing:3px;color:var(--gray-300);font-weight:300}

/* === SYSTEM PAGE === */
.system-hero{padding:calc(var(--nav-h) + 100px) 0 80px;text-align:center}
.system-steps{padding:80px 0;background:var(--gray-100)}
.steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;margin-top:64px}
.step-card{text-align:center;padding:40px 24px}
.step-num{font-family:var(--font-display);font-size:48px;font-weight:300;color:var(--sage);margin-bottom:16px}
.step-card h3{font-size:16px;font-weight:400;margin-bottom:12px}
.step-card p{font-size:13px;color:var(--gray-500);line-height:1.7}
.step-arrow{display:flex;align-items:center;justify-content:center;color:var(--gray-300);font-size:24px;padding-top:40px}

.system-specs{padding:100px 0}
.specs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:64px}
.spec-item{padding:32px;background:var(--gray-100);border-left:3px solid var(--sage)}
.spec-item h4{font-size:13px;letter-spacing:1px;margin-bottom:8px;font-family:var(--font-display)}
.spec-item p{font-size:14px;color:var(--gray-500)}

.system-compare{padding:100px 0;background:var(--gray-100)}
.compare-table{margin-top:64px;width:100%;border-collapse:collapse;font-size:14px}
.compare-table th{text-align:left;padding:16px 24px;font-weight:400;font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--gray-400);border-bottom:2px solid var(--gray-300);font-family:var(--font-display)}
.compare-table td{padding:16px 24px;border-bottom:1px solid var(--gray-200)}
.compare-table tr td:last-child{color:var(--sage);font-weight:500}

.system-hex-diagram{padding:100px 0;text-align:center}
.hex-grid-demo{display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin-top:64px;max-width:600px;margin-left:auto;margin-right:auto}
.hex-demo-cell{width:80px;height:70px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);background:var(--sage-light);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:14px;color:var(--sage);transition:all .3s}
.hex-demo-cell:hover{background:var(--sage);color:var(--white)}

/* === MODULES PAGE === */
.modules-hero{padding:calc(var(--nav-h) + 100px) 0 60px;text-align:center}
.modules-grid{padding:40px 0 100px}
.mod-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.mod-card{border:1px solid var(--gray-200);padding:48px 36px;position:relative;overflow:hidden;transition:all .5s var(--ease-out)}
.mod-card:hover{transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,.06)}
.mod-hex-icon{width:64px;height:56px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);margin-bottom:24px;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:18px;font-weight:500;color:var(--white)}
.mod-card h3{font-family:var(--font-display);font-size:20px;font-weight:400;margin-bottom:4px}
.mod-card .mod-en{font-size:11px;letter-spacing:1.5px;color:var(--gray-400);text-transform:uppercase;margin-bottom:16px;font-family:var(--font-display)}
.mod-card p{font-size:14px;color:var(--gray-500);line-height:1.8;margin-bottom:20px}
.mod-specs{display:flex;gap:16px;flex-wrap:wrap}
.mod-spec-tag{font-size:11px;padding:4px 12px;background:var(--gray-100);color:var(--gray-500);letter-spacing:.5px}

.modules-combo{padding:80px 0;background:var(--gray-100)}
.combo-examples{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:48px}
.combo-card{background:var(--white);padding:32px;text-align:center}
.combo-hexes{display:flex;justify-content:center;gap:4px;margin-bottom:16px;flex-wrap:wrap}
.combo-hex{width:40px;height:35px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%)}
.combo-card h4{font-size:14px;font-weight:400;margin-bottom:8px;font-family:var(--font-display)}
.combo-card p{font-size:13px;color:var(--gray-500)}

/* === EDITOR PAGE === */
.editor-page{padding-top:var(--nav-h);height:100vh;display:flex;flex-direction:column}
.editor-toolbar{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-bottom:1px solid var(--gray-200);background:var(--white)}
.editor-toolbar-left{display:flex;gap:8px}
.editor-toolbar-left button{padding:8px 16px;font-size:12px;letter-spacing:.5px;border:1px solid var(--gray-200);background:var(--white);transition:all .3s}
.editor-toolbar-left button:hover{border-color:var(--black);background:var(--gray-100)}
.tool-btn.active{background:var(--sage)!important;color:var(--white)!important;border-color:var(--sage)!important}
.toolbar-dropdown{position:relative;display:inline-block}
.toolbar-dropdown button{padding:8px 16px;font-size:12px;letter-spacing:.5px;border:1px solid var(--gray-200);background:var(--white);transition:all .3s;cursor:pointer}
.dropdown-menu{display:none;position:absolute;top:100%;left:0;background:var(--white);border:1px solid var(--gray-200);min-width:160px;z-index:100;margin-top:4px;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.dropdown-menu.show{display:block}
.dropdown-item{padding:10px 16px;font-size:12px;cursor:pointer;transition:background .2s}
.dropdown-item:hover{background:var(--gray-100)}
.preview-hint{font-size:11px;color:var(--sage);padding:4px 12px;background:var(--sage-light);border-radius:12px;margin-left:8px;font-weight:500}
.editor-toolbar-title{font-family:var(--font-display);font-size:14px;letter-spacing:1px}
.editor-body{display:flex;flex:1;overflow:hidden}
.editor-sidebar{width:220px;border-right:1px solid var(--gray-200);padding:24px;overflow-y:auto;flex-shrink:0}
.editor-sidebar h3{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);margin-bottom:16px;font-family:var(--font-display)}
.module-palette{display:flex;flex-direction:column;gap:8px}
.palette-item{display:flex;align-items:center;gap:12px;padding:10px 12px;border:2px solid transparent;cursor:pointer;transition:all .3s;border-radius:2px}
.palette-item:hover{background:var(--gray-100)}
.palette-item.selected{border-color:var(--black);background:var(--gray-100)}
.palette-hex{width:32px;height:28px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex-shrink:0}
.palette-info{font-size:12px;font-weight:300;position:relative}
.palette-info span{display:block;font-size:10px;color:var(--gray-400);margin-top:2px}
.pal-badge{position:absolute;top:-8px;right:-8px;background:var(--sage);color:white;font-size:10px;font-weight:700;min-width:16px;height:16px;line-height:16px;text-align:center;border-radius:8px;padding:0 4px;display:none}
.pal-badge.show{display:block}
.editor-canvas{flex:1;background:var(--gray-100);position:relative;overflow:hidden;cursor:crosshair}
.editor-canvas svg{width:100%;height:100%}
.editor-stats{width:240px;border-left:1px solid var(--gray-200);padding:24px;overflow-y:auto;flex-shrink:0}
.editor-stats h3{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);margin-bottom:16px;font-family:var(--font-display)}
.stat-row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--gray-100);font-size:13px}
.stat-row .val{font-family:var(--font-display);font-weight:500}
.stat-section{margin-bottom:24px}
.module-counts{margin-top:12px}
.mod-count-row{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:12px}
.mod-count-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}
.sustainability-bar{margin-top:16px}
.sus-bar-bg{height:6px;background:var(--gray-200);margin-top:8px;position:relative}
.sus-bar-fill{height:100%;background:var(--sage);transition:width .5s var(--ease-out)}
.sus-label{font-size:12px;color:var(--gray-500)}

/* === LOGIN PAGE === */
.login-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding-top:var(--nav-h);background:var(--gray-100)}
.login-card{background:var(--white);width:100%;max-width:440px;padding:56px 48px;box-shadow:0 2px 40px rgba(0,0,0,.04)}
.login-card .logo{font-family:var(--font-display);font-size:24px;letter-spacing:3px;text-align:center;margin-bottom:8px}
.login-card .logo-sub{text-align:center;font-size:12px;color:var(--gray-400);margin-bottom:40px;letter-spacing:1px}
.login-tabs{display:flex;margin-bottom:32px;border-bottom:1px solid var(--gray-200)}
.login-tab{flex:1;text-align:center;padding:12px;font-size:13px;letter-spacing:1px;cursor:pointer;border-bottom:2px solid transparent;transition:all .3s;color:var(--gray-400)}
.login-tab.active{color:var(--black);border-color:var(--black)}
.form-group{margin-bottom:20px}
.form-group label{display:block;font-size:12px;letter-spacing:.5px;color:var(--gray-500);margin-bottom:8px}
.form-group input,.form-group select{width:100%;padding:12px 16px;border:1px solid var(--gray-200);background:var(--white);font-size:14px;transition:border-color .3s;outline:none}
.form-group input:focus,.form-group select:focus{border-color:var(--black)}
.form-row{display:flex;gap:16px}
.form-row .form-group{flex:1}
.form-check{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--gray-500)}
.form-check input{width:auto}
.form-bottom{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
.form-link{font-size:12px;color:var(--sage);cursor:pointer}
.login-form .btn{width:100%;justify-content:center;margin-bottom:24px}
.social-divider{text-align:center;font-size:12px;color:var(--gray-400);margin-bottom:20px;position:relative}
.social-divider::before,.social-divider::after{content:'';position:absolute;top:50%;width:calc(50% - 40px);height:1px;background:var(--gray-200)}
.social-divider::before{left:0}
.social-divider::after{right:0}
.social-btns{display:flex;gap:12px}
.social-btn{flex:1;padding:12px;border:1px solid var(--gray-200);text-align:center;font-size:13px;transition:all .3s;cursor:pointer}
.social-btn:hover{border-color:var(--black)}
.login-form{transition:opacity .3s}
.login-form.hidden{display:none}
.form-group{position:relative}
.form-group input.error,.form-group select.error{border-color:#e53935}
.form-error{color:#e53935;font-size:11px;margin-top:4px;display:block;min-height:16px}
.form-group input.error~.form-error{color:#e53935}
.form-group-password{position:relative}
.password-toggle{position:absolute;right:12px;top:36px;background:none;border:none;cursor:pointer;padding:4px;opacity:.5;transition:opacity .3s}
.password-toggle:hover{opacity:1}
.password-toggle svg{width:20px;height:20px;fill:var(--gray-400)}
.password-strength{margin-top:8px;display:none}
.password-strength.show{display:block}
.strength-bar{height:4px;background:var(--gray-200);border-radius:2px;overflow:hidden}
.strength-fill{height:100%;transition:all .3s;width:0}
.strength-text{font-size:11px;color:var(--gray-400);margin-top:4px;display:block}
.strength-fill.weak{width:33%;background:#e53935}
.strength-fill.medium{width:66%;background:#ff9800}
.strength-fill.strong{width:100%;background:#4caf50}
.strength-fill.weak+.strength-text{color:#e53935}
.strength-fill.medium+.strength-text{color:#ff9800}
.strength-fill.strong+.strength-text{color:#4caf50}
.required{color:#e53935}
.btn{position:relative;overflow:hidden}
.btn-loading{display:flex;align-items:center;justify-content:center;gap:8px}
.spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%}
@keyframes spin{to{transform:rotate(360deg)}}
.spinner{animation:spin .8s linear infinite}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;z-index:2000;backdrop-filter:blur(4px)}
.modal-overlay.show{display:flex}
.search-content{background:var(--white);border-radius:16px;padding:24px;width:90%;max-width:600px;max-height:80vh;overflow:hidden;display:flex;flex-direction:column}
.search-header{display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--gray-200);padding-bottom:16px;margin-bottom:16px}
.search-header input{flex:1;border:none;outline:none;font-size:16px;background:transparent}
.search-results{flex:1;overflow-y:auto}
.search-hint{color:var(--gray-400);font-size:13px;text-align:center;padding:24px}
.search-item{padding:12px 16px;border-radius:8px;cursor:pointer;transition:background .2s;margin-bottom:4px}
.search-item:hover{background:var(--gray-100)}
.search-item-title{font-weight:500;color:var(--black);margin-bottom:4px}
.search-item-desc{font-size:12px;color:var(--gray-500);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.search-item-section{font-size:11px;color:var(--sage);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.modal-content{background:var(--white);padding:40px;max-width:400px;width:90%;position:relative;animation:modalIn .3s ease}
@keyframes modalIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
.modal-close{position:absolute;top:12px;right:12px;background:none;border:none;font-size:24px;cursor:pointer;color:var(--gray-400);transition:color .3s}
.modal-close:hover{color:var(--black)}
.modal-header{text-align:center;margin-bottom:24px}
.modal-header h3{font-family:var(--font-display);font-weight:400;font-size:20px;margin-bottom:8px}
.modal-header p{font-size:13px;color:var(--gray-400)}
.modal-success{text-align:center}
.success-icon{width:64px;height:64px;background:var(--sage-light);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
.success-icon svg{width:32px;height:32px;fill:var(--sage)}
.toast-container{position:fixed;top:80px;right:20px;z-index:3000;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--white);padding:14px 20px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.1);display:flex;align-items:center;gap:12px;animation:toastIn .3s ease;min-width:280px}
@keyframes toastIn{from{opacity:0;transform:translateX(100%)}to{opacity:1;transform:translateX(0)}}
.toast.toast-out{animation:toastOut .3s ease forwards}
@keyframes toastOut{to{opacity:0;transform:translateX(100%)}}
.toast-icon{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.toast-icon svg{width:14px;height:14px;fill:#fff}
.toast.success .toast-icon{background:#4caf50}
.toast.error .toast-icon{background:#e53935}
.toast.info .toast-icon{background:#2196f3}
.toast.warning .toast-icon{background:#ff9800}
.toast-message{font-size:14px;color:var(--black)}
.user-dropdown{position:relative}
.user-dropdown-btn{display:flex;align-items:center;gap:8px;background:none;border:none;cursor:pointer;padding:6px 12px;border-radius:20px;transition:background .3s}
.user-dropdown-btn:hover{background:var(--gray-100)}
.user-avatar{width:28px;height:28px;border-radius:50%;background:var(--sage-light);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);color:var(--sage);font-size:12px}
.user-dropdown-btn svg{fill:var(--gray-400)}
.user-dropdown-menu{position:absolute;top:100%;right:0;background:var(--white);min-width:160px;box-shadow:0 4px 20px rgba(0,0,0,.1);border-radius:8px;overflow:hidden;display:none;z-index:1001}
.user-dropdown-menu.show{display:block}
.user-dropdown-menu a{display:block;padding:12px 16px;font-size:13px;color:var(--gray-600);transition:all .3s}
.user-dropdown-menu a:hover{background:var(--gray-100);color:var(--black)}

/* === DASHBOARD PAGE === */
.dash-layout{display:flex;min-height:100vh;padding-top:var(--nav-h)}
.dash-sidebar{width:240px;background:var(--white);border-right:1px solid var(--gray-200);padding:32px 0;flex-shrink:0}
.dash-user{padding:0 24px 24px;border-bottom:1px solid var(--gray-200);margin-bottom:16px}
.dash-avatar{width:48px;height:48px;border-radius:50%;background:var(--sage-light);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);color:var(--sage);font-size:18px;margin-bottom:12px;overflow:hidden}
.dash-avatar img{width:100%;height:100%;object-fit:cover}
.avatar-edit-wrap{width:80px;height:80px;border-radius:50%;margin:0 auto;cursor:pointer;position:relative;overflow:hidden}
.avatar-preview{width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--gray-200)}
.avatar-edit-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;border-radius:50%}
.avatar-edit-wrap:hover .avatar-edit-overlay{opacity:1}
.avatar-edit-overlay span{color:white;font-size:10px;margin-top:4px}
.dash-user h4{font-size:14px;font-weight:400}
.dash-user span{font-size:12px;color:var(--gray-400)}
.dash-nav a{display:flex;align-items:center;gap:12px;padding:12px 24px;font-size:13px;color:var(--gray-500);transition:all .3s;border-left:3px solid transparent}
.dash-nav a:hover,.dash-nav a.active{color:var(--black);background:var(--gray-100);border-left-color:var(--sage)}
.dash-main{flex:1;background:var(--gray-100);padding:32px}
.dash-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:32px}
.dash-stat{background:var(--white);padding:24px;text-align:center}
.dash-stat .num{font-family:var(--font-display);font-size:32px;font-weight:300;color:var(--sage)}
.dash-stat .label{font-size:12px;color:var(--gray-400);margin-top:4px;letter-spacing:.5px}
.dash-designs{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px}
.design-card{background:var(--white);overflow:hidden;transition:all .3s;display:flex;flex-direction:column;position:relative}
.design-card:hover{box-shadow:0 8px 30px rgba(0,0,0,.06)}
.design-load-btn{margin:12px 16px 16px;padding:8px 16px;background:var(--black);color:var(--white);border:none;font-size:12px;letter-spacing:1px;cursor:pointer;transition:background .3s}
.design-load-btn:hover{background:var(--sage)}
.design-delete-btn{position:absolute;top:8px;right:8px;width:24px;height:24px;border-radius:50%;background:rgba(0,0,0,.5);color:white;border:none;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
.design-card:hover .design-delete-btn{opacity:1}
.design-delete-btn:hover{background:rgba(200,50,50,.8)}
.design-thumb{height:160px;background:linear-gradient(135deg,var(--sage-light),var(--beige-light));display:flex;align-items:center;justify-content:center;position:relative}
.design-thumb-hexes{display:flex;gap:2px;flex-wrap:wrap;max-width:120px;justify-content:center}
.design-screenshot{width:100%;height:100%;object-fit:cover}
.design-thumb-hex{width:24px;height:21px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%)}
.design-info{padding:16px}
.design-info h4{font-size:14px;font-weight:400;margin-bottom:4px}
.design-info span{font-size:12px;color:var(--gray-400)}

/* === DEALER DASHBOARD === */
.dealer-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:32px}
.kpi-card{background:var(--white);padding:24px}
.kpi-card .kpi-label{font-size:11px;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;font-family:var(--font-display)}
.kpi-card .kpi-val{font-family:var(--font-display);font-size:28px;font-weight:300}
.kpi-card .kpi-change{font-size:12px;margin-top:4px}
.kpi-up{color:var(--sage)}
.kpi-down{color:#c45d5d}
.dealer-chart{background:var(--white);padding:32px;margin-bottom:32px}
.chart-bars{display:flex;align-items:flex-end;gap:12px;height:180px;margin-top:24px}
.chart-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px}
.chart-bar{width:100%;background:var(--sage);border-radius:2px 2px 0 0;transition:height .5s var(--ease-out)}
.chart-bar-label{font-size:10px;color:var(--gray-400)}
.dealer-table{background:var(--white);padding:32px}
.dealer-table table{width:100%;border-collapse:collapse;font-size:13px}
.dealer-table th{text-align:left;padding:12px 16px;font-weight:400;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--gray-400);border-bottom:2px solid var(--gray-200);font-family:var(--font-display)}
.dealer-table td{padding:12px 16px;border-bottom:1px solid var(--gray-100)}
.status-badge{font-size:11px;padding:3px 10px;border-radius:2px}
.status-active{background:var(--sage-light);color:var(--sage)}
.status-pending{background:var(--beige-light);color:var(--beige)}
.status-done{background:var(--gray-100);color:var(--gray-500)}

/* === CASES PAGE === */
.cases-hero{padding:calc(var(--nav-h) + 100px) 0 40px;text-align:center}
.cases-filters{display:flex;justify-content:center;gap:8px;margin:40px 0}
.filter-btn{padding:8px 24px;font-size:13px;border:1px solid var(--gray-200);transition:all .3s;letter-spacing:.5px}
.filter-btn:hover,.filter-btn.active{background:var(--black);color:var(--white);border-color:var(--black)}
.cases-grid{columns:3;column-gap:24px;padding-bottom:100px}
.case-card{break-inside:avoid;margin-bottom:24px;overflow:hidden;border:1px solid var(--gray-200);transition:all .4s var(--ease-out)}
.case-card:hover{box-shadow:0 16px 48px rgba(0,0,0,.08)}
.case-img{height:var(--case-h,240px);background:linear-gradient(135deg,var(--c1,var(--sage-light)),var(--c2,var(--beige-light)));display:flex;align-items:center;justify-content:center;position:relative}
.case-img-hex{display:flex;gap:3px;flex-wrap:wrap;max-width:100px;justify-content:center;opacity:.4}
.case-img-hex div{width:30px;height:26px;clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);background:rgba(0,0,0,.15)}
.case-info{padding:20px}
.case-info h4{font-size:15px;font-weight:400;margin-bottom:4px;font-family:var(--font-display)}
.case-info .loc{font-size:12px;color:var(--gray-400);margin-bottom:8px}
.case-tags{display:flex;gap:6px;flex-wrap:wrap}
.case-tag{font-size:10px;padding:3px 8px;background:var(--gray-100);color:var(--gray-500)}

/* === ABOUT PAGE === */
.about-hero{padding:calc(var(--nav-h) + 100px) 0 80px}
.about-hero-split{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-hero-visual{height:400px;background:linear-gradient(135deg,var(--sage-light),var(--beige-light));display:flex;align-items:center;justify-content:center}
.about-timeline{padding:100px 0;background:var(--gray-100)}
.timeline{margin-top:64px;position:relative;padding-left:48px}
.timeline::before{content:'';position:absolute;left:18px;top:0;bottom:0;width:1px;background:var(--gray-300)}
.timeline-item{position:relative;margin-bottom:48px;padding-left:32px}
.timeline-item::before{content:'';position:absolute;left:-35px;top:8px;width:10px;height:10px;background:var(--sage);border-radius:50%}
.timeline-year{font-family:var(--font-display);font-size:14px;letter-spacing:2px;color:var(--sage);margin-bottom:8px}
.timeline-item h4{font-size:16px;font-weight:400;margin-bottom:4px}
.timeline-item p{font-size:14px;color:var(--gray-500)}
.about-sustain{padding:100px 0}
.sustain-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;margin-top:64px}
.sustain-metric{text-align:center}
.sustain-metric .num{font-family:var(--font-display);font-size:48px;font-weight:300;color:var(--sage)}
.sustain-metric .unit{font-size:14px;color:var(--gray-500)}
.sustain-metric .desc{font-size:12px;color:var(--gray-400);margin-top:8px}

/* === PARTNER PAGE === */
.partner-hero{height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--black) 0%,#1a1a1a 100%)}
.partner-hero-bg{position:absolute;inset:0;opacity:.08}
.partner-hero-bg svg{width:100%;height:100%}
.partner-hero-content{text-align:center;position:relative;z-index:2;padding:0 24px}
.partner-hero h1{font-family:var(--font-display);font-size:clamp(36px,6vw,72px);font-weight:300;letter-spacing:6px;margin-bottom:24px;color:var(--white);line-height:1.2}
.partner-hero h1 span{color:var(--sage)}
.partner-hero-subtitle{font-size:clamp(16px,2vw,22px);font-weight:300;color:var(--gray-400);letter-spacing:2px;max-width:600px;margin:0 auto}
.partner-hero-cta{margin-top:48px}
.partner-scroll-hint{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);color:var(--gray-500);font-size:12px;letter-spacing:2px;animation:float 2s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-10px)}}

.partner-opportunity{padding:120px 0;background:var(--white)}
.opportunity-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:64px}
.opp-card{padding:40px 32px;text-align:center;border:1px solid var(--gray-200);transition:all .4s var(--ease-out)}
.opp-card:hover{border-color:var(--sage);transform:translateY(-4px)}
.opp-icon{width:64px;height:64px;margin:0 auto 24px;display:flex;align-items:center;justify-content:center}
.opp-icon svg{width:48px;height:48px;stroke:var(--sage);fill:none;stroke-width:1.5}
.opp-card h3{font-family:var(--font-display);font-size:18px;font-weight:400;margin-bottom:12px}
.opp-card p{font-size:14px;color:var(--gray-500);line-height:1.7}
.opp-stat{font-family:var(--font-display);font-size:36px;color:var(--sage);margin-bottom:8px;font-weight:300}

.partner-advantages{padding:120px 0;background:var(--gray-100)}
.adv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;margin-top:64px}
.adv-card{background:var(--white);padding:40px 28px;text-align:center;transition:all .4s var(--ease-out)}
.adv-card:hover{box-shadow:0 16px 48px rgba(0,0,0,.06)}
.adv-icon{width:56px;height:56px;margin:0 auto 20px;background:var(--sage-light);border-radius:50%;display:flex;align-items:center;justify-content:center}
.adv-icon svg{width:28px;height:28px;stroke:var(--sage);fill:none;stroke-width:1.5}
.adv-card h4{font-family:var(--font-display);font-size:16px;font-weight:400;margin-bottom:8px}
.adv-card p{font-size:13px;color:var(--gray-500);line-height:1.6}

.partner-profit{padding:120px 0;background:var(--white)}
.profit-intro{text-align:center;max-width:700px;margin:0 auto 64px}
.profit-intro h3{font-family:var(--font-display);font-size:28px;font-weight:300;margin-bottom:16px}
.profit-intro p{font-size:16px;color:var(--gray-500);line-height:1.8}
.profit-model{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.profit-card{background:var(--gray-100);padding:40px;text-align:center;position:relative;overflow:hidden}
.profit-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--sage)}
.profit-card h4{font-family:var(--font-display);font-size:20px;font-weight:400;margin-bottom:16px}
.profit-card p{font-size:14px;color:var(--gray-500);line-height:1.7;margin-bottom:20px}
.profit-highlight{font-family:var(--font-display);font-size:24px;color:var(--sage);font-weight:300}
.quote-mark{font-family:var(--font-display);font-size:48px;color:var(--sage-light);line-height:1;margin-bottom:16px}

.partner-support{padding:120px 0;background:var(--black);color:var(--white)}
.partner-support .section-label{color:var(--gray-500)}
.partner-support .section-title{color:var(--white)}
.support-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;margin-top:64px}
.support-card{text-align:center}
.support-icon{width:72px;height:72px;margin:0 auto 24px;background:rgba(122,158,126,.15);border:1px solid rgba(122,158,126,.3);border-radius:50%;display:flex;align-items:center;justify-content:center}
.support-icon svg{width:32px;height:32px;stroke:var(--sage);fill:none;stroke-width:1.5}
.support-card h4{font-family:var(--font-display);font-size:16px;font-weight:400;margin-bottom:8px}
.support-card p{font-size:13px;color:var(--gray-500);line-height:1.6}

.partner-cta{padding:120px 0;background:linear-gradient(180deg,var(--black) 0%,var(--sage) 100%);text-align:center;color:var(--white)}
.partner-cta h2{font-family:var(--font-display);font-size:clamp(28px,4vw,48px);font-weight:300;margin-bottom:24px;letter-spacing:2px}
.partner-cta p{font-size:16px;color:rgba(255,255,255,.7);max-width:500px;margin:0 auto 40px;line-height:1.8}
.partner-cta .btn{background:var(--white);color:var(--black);border-color:var(--white);font-size:14px;padding:16px 48px}
.partner-cta .btn:hover{background:transparent;color:var(--white)}
.partner-cta-note{font-size:13px;color:rgba(255,255,255,.5);margin-top:24px}

/* === CONTACT PAGE === */
.contact-page{padding:calc(var(--nav-h) + 80px) 0 100px}
.contact-split{display:grid;grid-template-columns:1fr 1fr;gap:80px}
.contact-form .form-group textarea{width:100%;padding:12px 16px;border:1px solid var(--gray-200);background:var(--white);font-size:14px;resize:vertical;min-height:120px;outline:none;transition:border-color .3s}
.contact-form .form-group textarea:focus{border-color:var(--black)}
.contact-info-block{margin-bottom:32px}
.contact-info-block h4{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gray-400);margin-bottom:12px;font-family:var(--font-display)}
.contact-info-block p{font-size:14px;color:var(--gray-500);line-height:1.8}

/* === ANIMATIONS === */
.reveal{opacity:0;transform:translateY(30px);transition:all .8s var(--ease-out)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.1s}
.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}
.reveal-delay-4{transition-delay:.4s}

/* === RESPONSIVE ADDITIONS === */
@media(max-width:900px){
.home-philosophy-grid,.steps-grid{grid-template-columns:1fr}
.mod-cards{grid-template-columns:1fr}
.about-hero-split{grid-template-columns:1fr}
.contact-split{grid-template-columns:1fr}
.combo-examples{grid-template-columns:1fr}
.dealer-kpis{grid-template-columns:repeat(2,1fr)}
.cases-grid{columns:1}
.sustain-metrics{grid-template-columns:repeat(2,1fr)}
.editor-sidebar,.editor-stats{display:none}
.dash-sidebar{display:none}
.specs-grid{grid-template-columns:1fr}
.step-arrow{display:none}
.opportunity-grid,.adv-grid,.profit-model,.support-grid{grid-template-columns:1fr}
}
@media(max-width:600px){
.dealer-kpis{grid-template-columns:1fr}
.sustain-metrics{grid-template-columns:1fr}
.dash-stats{grid-template-columns:1fr}
}
</style>
