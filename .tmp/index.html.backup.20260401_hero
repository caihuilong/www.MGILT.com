/* === DASHBOARD DESIGNS === */
function initDashDesigns(){
  const container=document.getElementById('dashDesigns');if(!container)return;
  const savedDesigns=JSON.parse(localStorage.getItem('mgilt_designs')||'[]');
  const editorModColors={0:'#5B8C5A',1:'#7A9E7E',2:'#BFA27A',3:'#8B7EB8',4:'#A0887A',5:'#5A7A8B'};
  if(savedDesigns.length===0){
    container.innerHTML='<div style="text-align:center;padding:60px 20px;color:var(--gray-400)"><p style="font-size:14px">暂无设计方案</p><p style="font-size:12px;margin-top:8px">去设计你的MGILT创建第一个设计</p></div>';
    return;
  }
  container.innerHTML=savedDesigns.reverse().map(d=>{
    const modIds=Object.values(d.modules||{});
    const uniqueMods=[...new Set(modIds)];
    const hexes=uniqueMods.slice(0,6).map(m=>`<div class="design-thumb-hex" style="background:${editorModColors[m]||'#ccc'}"></div>`).join('');
    const date=new Date(d.timestamp).toLocaleDateString('zh-CN');
    const total=modIds.length;
    const preview=d.screenshot?`<img src="${d.screenshot}" class="design-screenshot" alt="设计预览">`:`<div class="design-thumb-hexes">${hexes}</div>`;
    return`<div class="design-card"><div class="design-thumb">${preview}</div><button class="design-delete-btn" onclick="showDeleteConfirm(${d.id})" title="删除">×</button><div class="design-info"><h4>${d.name||'设计方案'}</h4><span>${date} · ${total} 模块</span></div><button class="design-load-btn" onclick="loadDesignToEditor(${d.id})">编辑</button></div>`;
  }).join('');
}
function showDashDesigns(){
  document.querySelectorAll('.dash-nav a').forEach(a=>a.classList.remove('active'));
  document.querySelector('.dash-nav a')?.classList.add('active');
  initDashDesigns();
}
let pendingDeleteId=null;
function showDeleteConfirm(id){
  pendingDeleteId=id;
  const savedDesigns=JSON.parse(localStorage.getItem('mgilt_designs')||'[]');
  const design=savedDesigns.find(d=>d.id===id);
  const name=design?design.name:'该方案';
  document.getElementById('deleteConfirmText').textContent='确定要删除方案「'+name+'」吗？此操作不可撤销。';
  document.getElementById('deleteConfirmModal').classList.add('show');
}
function closeDeleteConfirm(){
  pendingDeleteId=null;
  document.getElementById('deleteConfirmModal').classList.remove('show');
}
function confirmDeleteDesign(){
  if(pendingDeleteId===null)return;
  let savedDesigns=JSON.parse(localStorage.getItem('mgilt_designs')||'[]');
  savedDesigns=savedDesigns.filter(d=>d.id!==pendingDeleteId);
  localStorage.setItem('mgilt_designs',JSON.stringify(savedDesigns));
  closeDeleteConfirm();
  initDashDesigns();
  showToast('success','方案已删除');
}
window.showDeleteConfirm=showDeleteConfirm;
