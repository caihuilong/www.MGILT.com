  document.querySelectorAll('.nav-links a').forEach(a=>{a.classList.toggle('active',a.dataset.page===hash)});
  window.scrollTo(0,0);
  // Hide footer on editor/dashboard/dealer pages
  const hideFooter=['editor','dashboard','dealer'];
  document.getElementById('mainFooter').style.display=hideFooter.includes(hash)?'none':'block';
  setTimeout(initPageAnimations,150);
  if(hash==='editor') setTimeout(initEditor,200);
  if(hash==='home') initHomeVisuals();
  if(hash==='system') initSystemDiagram();
  if(hash==='cases') initCases();
  if(hash==='dashboard') initDashDesigns();
  if(hash==='dealer') initDealerChart();
  if(hash==='partner') initPartnerChart();
  if(hash==='login') showTab('login');
}

