  document.getElementById('searchResults').innerHTML = '<div class="search-hint">输入关键词搜索首页、模块系统、空间灵感等内容</div>';
  setTimeout(() => document.getElementById('searchInput').focus(), 100);
}
function closeSearch(){
  document.getElementById('searchModal').classList.remove('show');
}
function doSearch(query){
  const resultsEl = document.getElementById('searchResults');
  if (!query || query.trim().length < 1) {
    resultsEl.innerHTML = '<div class="search-hint">输入关键词搜索首页、模块系统、空间灵感等内容</div>';
    return;
  }
  const q = query.toLowerCase().trim();
  const results = SEARCH_INDEX.filter(item =>
    item.title.toLowerCase().includes(q) ||
    item.desc.toLowerCase().includes(q) ||
    item.section.toLowerCase().includes(q)
  );
  if (results.length === 0) {
    resultsEl.innerHTML = '<div class="search-hint">未找到相关结果，请尝试其他关键词</div>';
    return;
  }
  resultsEl.innerHTML = results.map(item => `
    <div class="search-item" onclick="navigateAndCloseSearch('${item.section}','${item.anchor}')">
      <div class="search-item-section">${item.section}</div>
      <div class="search-item-title">${item.title}</div>
      <div class="search-item-desc">${item.desc}</div>
    </div>
  `).join('');
}
function navigateAndCloseSearch(section, anchor){
  const sectionMap = { '首页': 'home', '模块系统': 'system', '空间灵感': 'cases', '设计你的MGILT': 'editor', '关于MGILT': 'about', '合作伙伴': 'partner' };
  const page = sectionMap[section] || 'home';
  closeSearch();
  navigateTo(page);
  setTimeout(() => {
    const el = document.getElementById(anchor);
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }, 300);
}
function handleUserIconClick(){
  if (isLoggedIn()) {
    toggleUserMenu();
  } else {
    navigateTo('login');
  }
}
window.showSearch=showSearch;
window.closeSearch=closeSearch;
window.doSearch=doSearch;
window.handleUserIconClick=handleUserIconClick;
window.navigateAndCloseSearch=navigateAndCloseSearch;

